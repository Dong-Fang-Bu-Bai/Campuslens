HOST=0.0.0.0
PORT=8000

DATASETS_DIR=../datasets/landmarks
FAISS_INDEX_DIR=./data/faiss_index
FEATURES_CACHE_DIR=./data/features

DINO_MODEL_PATH=./models/dinov2_model.pth
DEVICE=auto
IMAGE_SIZE=518
BATCH_SIZE=32
SEARCH_BATCH_SIZE=2
MIXED_PRECISION=false

TOP_K_RESULTS=5
# Legacy compatibility setting. Current FAISS scoring uses sigmoid empirical match score thresholds in app/utils/scoring.py.
CONFIDENCE_THRESHOLD=0.5

# SAR is disabled by default. Enable only after local baseline comparison.
SAR_ENABLED=true
SAR_STEPS=1
SAR_ENTROPY_TEMPERATURE=0.15
SAR_ENTROPY_THRESHOLD=0.70
SAR_LEARNING_RATE=0.0001
SAR_RHO=0.05
SAR_EMA_ALPHA=0.9
SAR_COLLAPSE_EMA_THRESHOLD=0.05
SAR_ANCHOR_CHECK_INTERVAL=10
SAR_ANCHOR_TOP1_RETENTION=0.90
SAR_FEATURE_DRIFT_THRESHOLD=0.08
SAR_STATE_DIR=./data/model_versions/sar_runtime
SAR_EVENT_LOG=./data/logs/sar_events.jsonl
ANCHOR_DATASET_DIR=../datasets/anchors
MATCH_SCORE_CENTER_DISTANCE=700.0
MATCH_SCORE_SLOPE=5.0
SIGMOID_STABILITY_THRESHOLD=700.0
TRUST_LOW_THRESHOLD=0.35
TRUST_HIGH_THRESHOLD=0.70
CORRECTION_ACCEPT_CONFIDENCE=0.70
MODEL_VERSIONS_DIR=./data/model_versions

MAX_FILE_SIZE=10485760
