@backend = http://localhost:8080
@algorithm = http://localhost:8000
@adminToken = 请先执行管理员登录并复制返回 token
@userToken = 请先执行用户登录并复制返回 token
@guestId = guest-local-demo

### 后端健康检查
GET {{backend}}/api/health

### 获取地标列表
GET {{backend}}/api/landmarks

### 获取地标详情
GET {{backend}}/api/landmarks/1

### 普通用户注册
POST {{backend}}/api/auth/register
Content-Type: application/json

{
  "username": "student01",
  "password": "password123",
  "email": "student01@example.com"
}

### 用户登录
POST {{backend}}/api/auth/login
Content-Type: application/json

{
  "username": "student01",
  "password": "password123"
}

### 管理员隐式登录后台
POST {{backend}}/api/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "admin"
}

### 上传图片并检索 Top-5
POST {{backend}}/api/search/upload
Authorization: Bearer {{userToken}}
Content-Type: multipart/form-data; boundary=CampusLensBoundary

--CampusLensBoundary
Content-Disposition: form-data; name="file"; filename="sample.jpg"
Content-Type: image/jpeg

< ./sample.jpg
--CampusLensBoundary
Content-Disposition: form-data; name="guestId"

{{guestId}}
--CampusLensBoundary--

### 提交识别反馈：正确
# searchRecordId 需使用上一步上传接口返回的数据库记录 ID。
POST {{backend}}/api/feedback
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "searchRecordId": 1,
  "predictedLandmarkId": 1,
  "confirmedLandmarkId": 1,
  "guestId": "{{guestId}}",
  "feedbackType": "correct",
  "comment": "识别结果正确"
}

### 提交识别反馈：错误
POST {{backend}}/api/feedback
Content-Type: application/json

{
  "searchRecordId": 1,
  "predictedLandmarkId": 1,
  "confirmedLandmarkId": 2,
  "feedbackType": "wrong",
  "comment": "实际是学术大讲堂"
}

### 提交识别反馈：不确定
POST {{backend}}/api/feedback
Content-Type: application/json

{
  "searchRecordId": 1,
  "predictedLandmarkId": 1,
  "feedbackType": "uncertain",
  "comment": "照片角度较偏，无法确认候选地标"
}

### 当前登录用户个人历史
GET {{backend}}/api/me/search-records?limit=20
Authorization: Bearer {{userToken}}

### 查询打卡留言
GET {{backend}}/api/check-ins?limit=50&guestId={{guestId}}

### 发布打卡留言
POST {{backend}}/api/check-ins
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "landmarkId": 1,
  "message": "图书馆门口完成打卡，入口角度适合拍摄识别样本。",
  "guestId": "{{guestId}}"
}

### 点赞或取消点赞
POST {{backend}}/api/check-ins/1/like?guestId={{guestId}}
Authorization: Bearer {{userToken}}

### 回复打卡留言
POST {{backend}}/api/check-ins/1/replies
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "message": "同一位置傍晚光线也比较稳定。",
  "guestId": "{{guestId}}"
}

### 查看最近检索记录
GET {{backend}}/api/admin/search-records
Authorization: Bearer {{adminToken}}

### 查看反馈记录
GET {{backend}}/api/admin/feedback
Authorization: Bearer {{adminToken}}

### 查看反馈详情
GET {{backend}}/api/admin/feedback/1
Authorization: Bearer {{adminToken}}

### 处理反馈状态
POST {{backend}}/api/admin/feedback/1/status
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "status": "accepted"
}

### 新增地标
POST {{backend}}/api/admin/landmarks
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "code": "L11",
  "name": "新增测试地标",
  "englishName": "Library",
  "type": "建筑",
  "summary": "校园核心学习空间，建筑体量大、外立面辨识度高。",
  "description": "用于管理员新增地标接口联调。",
  "locationText": "文雍广场附近",
  "mapX": 50.0,
  "mapY": 50.0,
  "coverImageUrl": "/images/landmarks/l11.jpg"
}

### 重建统计参数
POST {{backend}}/api/admin/index/rebuild
Authorization: Bearer {{adminToken}}

### 算法服务检索接口
POST {{algorithm}}/api/v1/search
Content-Type: multipart/form-data; boundary=CampusLensAlgorithmBoundary

--CampusLensAlgorithmBoundary
Content-Disposition: form-data; name="file"; filename="sample.jpg"
Content-Type: image/jpeg

< ./sample.jpg
--CampusLensAlgorithmBoundary--

### 算法服务重建统计参数
POST {{algorithm}}/api/v1/index/rebuild

### 算法服务统计参数状态
GET {{algorithm}}/api/v1/index/stats

### 算法服务健康检查
GET {{algorithm}}/api/v1/health

### 算法服务校正样本接收接口
POST {{algorithm}}/api/v1/adaptation/correction-samples
Content-Type: application/json

{
  "sampleId": 1,
  "feedbackId": 1,
  "searchRecordId": 1,
  "imageUrl": "/uploads/20260608/sample.jpg",
  "confirmedLandmarkCode": "L02",
  "predictedLandmarkCode": "L01",
  "feedbackType": "wrong",
  "comment": "实际是学术大讲堂",
  "topResults": [
    { "rank": 1, "landmarkCode": "L01", "score": 0.91, "mahalanobisDistance": 3.12 },
    { "rank": 2, "landmarkCode": "L02", "score": 0.72, "mahalanobisDistance": 6.45 }
  ]
}
